# Godot 4+ specific ignores
.godot/
android/
.import/

# UID gerados pelo editor (cache local)
*.uid

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json
bin/

# System/tool-specific ignores
.directory
*~
*.tmp

# Godot crash logs (descomentar pra debug)
# crash.log

# Temporary scene/script backups do editor
*.tmp

# Local-only backup de preprocessadores de assets (se houver)
_addons/
