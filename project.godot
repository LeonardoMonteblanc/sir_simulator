; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ProjetoV2"
config/description="Simulador epidemiologico SEIRD em grafos (Teoria dos Grafos)"
run/main_scene="uid://bk34ptpuc8law"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SimConfig="*uid://cgqnh5rau5i7q"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/per_pixel_transparency/allowed=true

[gui]

theme/custom_font="uid://dsnd2cppfu0uw"

[importer_defaults]

texture={
&"detect_3d/compress_to": 0,
&"editor/scale_with_editor_scale": true,
&"process/hdr_as_srgb": true
}

[input]

ui_cancel={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194305,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[physics]

2d/run_on_separate_thread=true
3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
